# Devin API Configuration
DEVIN_API_KEY=your_devin_api_key_here
DEVIN_API_URL=https://api.devin.ai
# Optional: enterprise key for the aggregate ACU consumption API (falls back to
# DEVIN_API_KEY; requires the org to be entitled, else ACU stays unavailable).
# COG_API_KEY=

# GitHub Configuration
# IMPORTANT: the token must be able to WRITE issues and pull requests on your fork:
#   - Fine-grained PAT -> Repository permissions: Issues: Read and write,
#     Pull requests: Read and write, Contents: Read and write, Metadata: Read.
#   - Classic PAT -> the `repo` scope (or `public_repo` for a public fork).
# A read-only token fails with "403 Resource not accessible" when a scan files issues.
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=superset
GITHUB_FORK_URL=https://github.com/your_github_username/superset.git

# Concurrency Settings
MAX_ACU_LIMIT=10
MAX_CONCURRENT_SESSIONS=3

# Logging
LOG_LEVEL=INFO

# Database
DATABASE_PATH=data/state.db

# Scanner target
# By default the "Scan" buttons audit a checkout of GITHUB_FORK_URL at the tip of
# its default branch -- cloned and refreshed automatically at FORK_CHECKOUT_PATH,
# so no manual setup is needed. Set SCAN_REPO_PATH only to override with a specific
# local checkout.
# SCAN_REPO_PATH=
# FORK_CHECKOUT_PATH=superset-fork
# FORK_DEFAULT_BRANCH=master

# Cap on NEW issues (and therefore Devin sessions) created per run; 0 = unlimited.
MAX_NEW_ISSUES_PER_SCAN=5
