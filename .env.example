# Devin API Configuration
DEVIN_API_KEY=your_devin_api_key_here
DEVIN_API_URL=https://api.devin.ai

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=superset
GITHUB_FORK_URL=https://github.com/your_github_username/superset.git

# Concurrency Settings
MAX_ACU_LIMIT=10
MAX_CONCURRENT_SESSIONS=3

# Logging
LOG_LEVEL=INFO

# Database
DATABASE_PATH=data/state.db

# Superset Fork Path (for local development)
# This should point to your local clone of the Superset fork
# For Docker, this is mounted as ./superset-fork
SUPERSET_FORK_PATH=./superset-fork
